{
    "name": "turted/turted-bundle",
    "description": "Symfony Bundle to send Push messages to a TURTED server",
    "version": "5.0.1",
    "type": "vcs",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter Dietrich",
            "email": "pd@pd-it.de",
            "homepage": "https://pd-it.de",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Turted\\TurtedBundle\\": "src/"
        },
        "exclude-from-classmap": [
            "/Tests/"
        ]
    },
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0 || ^8.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0"
    }
}
